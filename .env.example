# Optional. The site works without this key, but live odds will be disabled.
ODDS_API_KEY=

# Optional. Protects /api/cron/nightly-refresh when deployed.
CRON_SECRET=

# Required for API-Football / API-Sports v3 result sync. Put the real key in .env.local.
API_FOOTBALL_KEY=

# Optional local override for scripts.
LOCAL_SITE_URL=http://127.0.0.1

# Optional persistent data directory for Node deployments.
WORLD_CUP_DATA_DIR=

# Local/Cloudflare safety gates.
APP_ENV=local
ALLOW_PRODUCTION_WRITES=false
SYNC_SOURCE=espn
SYNC_MANUAL_TRIGGER_ENABLED=true
